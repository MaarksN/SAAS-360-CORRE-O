# Sealed equivalent for .env.staging
# Keep real values only in GitHub Environment secrets/variables or vault.

NODE_ENV=production
DEPLOYMENT_ENVIRONMENT=staging
NEXT_PUBLIC_ENVIRONMENT=staging
LOG_LEVEL=info

NEXT_PUBLIC_APP_URL=https://staging.app.birthhub360.com
NEXT_PUBLIC_API_URL=https://staging.api.birthhub360.com
WEB_BASE_URL=https://staging.app.birthhub360.com
API_CORS_ORIGINS=https://staging.app.birthhub360.com

NEXT_PUBLIC_CSP_REPORT_ONLY=false
REQUIRE_SECURE_COOKIES=true

NEXT_PUBLIC_SENTRY_DSN=https://sealed-public-staging@example.ingest.sentry.io/1001
SENTRY_DSN=https://sealed-backend-staging@example.ingest.sentry.io/1002
SENTRY_ENVIRONMENT=staging

DATABASE_URL=postgresql://sealed_user:sealed_password@staging-postgres.internal:5432/birthub?sslmode=require
REDIS_URL=rediss://sealed_user:sealed_password@staging-redis.internal:6379

SESSION_SECRET=sealed_staging_session_secret_64_chars_minimum_value_xxxxxxxxxx
AUTH_MFA_ENCRYPTION_KEY=sealed_staging_mfa_encryption_key_64_chars_minimum_xxx
JOB_HMAC_GLOBAL_SECRET=sealed_staging_job_hmac_secret_64_chars_minimum_value_x

