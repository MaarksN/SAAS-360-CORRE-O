{
  "applications": [
    {
      "lane": "core",
      "packageName": "@birthub/api",
      "purpose": "Canonical multi-tenant API for release and production deploys.",
      "root": "apps/api"
    },
    {
      "lane": "core",
      "packageName": "@birthub/web",
      "purpose": "Canonical customer-facing control plane and app-router web surface.",
      "root": "apps/web"
    },
    {
      "lane": "core",
      "packageName": "@birthub/worker",
      "purpose": "Canonical worker runtime for queues, workflows and billing jobs.",
      "root": "apps/worker"
    },
    {
      "lane": "legacy",
      "packageName": "@birthub/dashboard",
      "purpose": "Legacy CRM cockpit on the canonical @birthub/database contract and excluded from the core release lane.",
      "root": "apps/legacy/dashboard"
    },
    {
      "lane": "legacy",
      "packageName": "orchestrator-worker",
      "purpose": "Legacy orchestration worker overlay limited to worker.ts and supported separately.",
      "root": "apps/agent-orchestrator"
    }
  ],
  "conflicts": [],
  "expectedScriptValues": [],
  "importRules": [
    {
      "allowedRoots": [
        "packages/db"
      ],
      "description": "@birthub/db is frozen legacy CRM schema. New code must use @birthub/database and imports are restricted to the packages/db compatibility layer only.",
      "packageName": "@birthub/db"
    },
    {
      "allowedRoots": [
        "apps/api",
        "apps/legacy/dashboard",
        "packages/db",
        "apps/web",
        "apps/worker",
        "packages/database",
        "packages/testing"
      ],
      "description": "@birthub/database is the multi-tenant SaaS schema and must not leak into legacy CRM workspaces.",
      "packageName": "@birthub/database"
    }
  ],
  "releaseCoreScripts": {
    "forbiddenFilters": [
      "@birthub/dashboard",
      "@birthub/voice-engine",
      "@birthub/webhook-receiver",
      "orchestrator-worker"
    ],
    "requiredByScript": {
      "build:core": [
        "@birthub/web",
        "@birthub/api",
        "@birthub/worker",
        "@birthub/testing"
      ],
      "dev": [
        "@birthub/web",
        "@birthub/api",
        "@birthub/worker"
      ],
      "lint:core": [
        "@birthub/web",
        "@birthub/api",
        "@birthub/worker",
        "@birthub/testing"
      ],
      "test:core": [
        "@birthub/web",
        "@birthub/api",
        "@birthub/worker",
        "@birthub/testing"
      ],
      "typecheck:core": [
        "@birthub/web",
        "@birthub/api",
        "@birthub/worker",
        "@birthub/testing"
      ]
    }
  }
}
