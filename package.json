{
  "name": "birthub-360",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "9.1.0"
  },
  "scripts": {
    "artifacts:clean": "node scripts/ci/cleanup-artifacts.mjs",
    "branch:check": "node scripts/ci/check-branch-name.mjs",
    "build": "corepack pnpm db:generate && corepack pnpm build:core && corepack pnpm release:sbom",
    "build:agents": "node scripts/ci/run-pnpm.mjs -r --if-present --filter \"*-agent-worker\" run build",
    "build:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing run build",
    "build:workspace": "turbo run build",
    "build:satellites": "node scripts/ci/run-satellites.mjs build",
    "bootstrap:local:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap/bootstrap-local.ps1",
    "bootstrap:node:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap/install-node-portable.ps1",
    "ci:commitlint": "node scripts/ci/check-commit-messages.mjs",
    "ci:core": "node scripts/ci/full.mjs task core",
    "ci:dirty-tree": "node scripts/ci/check-dirty-tree.mjs",
    "ci:full": "node scripts/ci/full.mjs full",
    "ci:legacy-db-surface-freeze": "node scripts/ci/check-legacy-db-surface-freeze.mjs",
    "ci:legacy-runtime-surface-freeze": "node scripts/ci/check-legacy-runtime-surface-freeze.mjs",
    "ci:lockfile": "node scripts/ci/lockfile-governance.mjs",
    "ci:security-guardrails": "node scripts/ci/security-guardrails-local.mjs",
    "ci:security-guardrails:strict": "node scripts/ci/security-guardrails-local.mjs --require-db",
    "ci:security-guardrails:local": "node scripts/ci/security-guardrails-local.mjs",
    "ci:satellites": "node scripts/ci/full.mjs task satellites",
    "dev": "turbo run dev --filter=@birthub/web --filter=@birthub/api --filter=@birthub/worker --parallel",
    "dev:legacy": "turbo run dev",
    "commits:check": "node scripts/ci/check-commit-messages.mjs",
    "docs:check-links": "node scripts/docs/check-doc-links.mjs",
    "stack:canonical": "corepack pnpm preflight:core && corepack pnpm dev",
    "stack:hybrid": "corepack pnpm preflight:full && corepack pnpm dev:legacy",
    "hygiene:check": "node scripts/ci/repo-hygiene.mjs",
    "audit:f2:db-imports": "node scripts/diagnostics/audit-legacy-db-imports.mjs",
    "audit:materialize:doc-only": "node scripts/diagnostics/materialize-doc-only-controls.mjs",
    "audit:ownership": "node scripts/diagnostics/check-ownership-governance.mjs",
    "audit:batch:logical": "node scripts/forensics/materialize-logical-batch.mjs",
    "audit:materialize:all": "corepack pnpm audit:materialize:doc-only && corepack pnpm audit:f2:db-imports && corepack pnpm audit:ownership",
    "audit:prepare": "node scripts/audit/prepare-history.mjs",
    "audit:generate": "node scripts/audit/generate-report.mjs",
    "audit:run": "node scripts/audit/prepare-history.mjs && node scripts/audit/generate-report.mjs",
    "lint": "corepack pnpm lint:policy && corepack pnpm lint:core",
    "lint:policy": "node scripts/ci/lint-policy.mjs",
    "lint:agents": "node scripts/ci/run-pnpm.mjs -r --if-present --filter \"*-agent-worker\" run lint",
    "lint:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing... --filter=@birthub/auth... --filter=@birthub/utils... run lint",
    "lint:satellites": "node scripts/ci/run-satellites.mjs lint",
    "lint:workspace": "turbo run lint",
    "preflight:agents": "node scripts/ci/preflight.mjs agents",
    "preflight:core": "node scripts/ci/preflight.mjs core",
    "preflight:full": "node scripts/ci/preflight.mjs full",
    "preflight:satellites": "node scripts/ci/preflight.mjs satellites",
    "preflight:workflow-suite": "node scripts/ci/preflight.mjs workflow-suite",
    "typecheck": "corepack pnpm typecheck:policy && corepack pnpm typecheck:core",
    "typecheck:policy": "node scripts/ci/ts-directives-guard.mjs",
    "typecheck:agents": "node scripts/ci/run-pnpm.mjs -r --if-present --filter \"*-agent-worker\" run typecheck",
    "typecheck:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing... --filter=@birthub/auth... --filter=@birthub/utils... run typecheck",
    "typecheck:satellites": "node scripts/ci/run-satellites.mjs typecheck",
    "typecheck:workspace": "turbo run typecheck",
    "test": "corepack pnpm test:core",
    "test:agents:packages": "node scripts/ci/run-pnpm.mjs -r --if-present --filter \"*-agent-worker\" run test",
    "test:core": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/web... --filter=@birthub/api... --filter=@birthub/worker... --filter=@birthub/testing... --filter=@birthub/auth... --filter=@birthub/utils... run test",
    "test:satellites": "node scripts/ci/run-satellites.mjs test",
    "test:workspace": "turbo run test",
    "test:isolation": "node scripts/ci/run-pnpm.mjs -r --if-present --filter=@birthub/api --filter=@birthub/worker run test:isolation",
    "test:db:proof": "corepack pnpm --filter @birthub/database test:proof && corepack pnpm --filter @birthub/api test:performance",
    "test:workflows": "corepack pnpm --filter @birthub/workflows-core test && corepack pnpm --filter @birthub/worker test && corepack pnpm workflow:coverage",
    "workflow:coverage": "node --import tsx scripts/verify-workflow-step-coverage.ts",
    "test:auth": "corepack pnpm --filter @birthub/api test:auth",
    "test:rbac": "corepack pnpm --filter @birthub/api test:rbac",
    "test:security": "corepack pnpm --filter @birthub/api test:security",
    "security:report": "tsx scripts/security/generate-security-report.ts",
    "security:guards": "corepack pnpm exec tsx scripts/security/check-auth-guards.ts",
    "security:inline-credentials": "node scripts/security/scan-inline-credentials.mjs",
    "packs:validate": "corepack pnpm --filter @birthub/agent-packs validate",
    "agents:compile:github": "node --import tsx scripts/agent/compile-github-agents.ts",
    "agents:readiness:github": "node --import tsx scripts/agent/check-github-agent-readiness.ts",
    "agents:industrialize:github": "corepack pnpm agents:compile:github && corepack pnpm agents:readiness:github",
    "packs:test": "corepack pnpm --filter @birthub/agent-packs test",
    "packs:smoke": "corepack pnpm --filter @birthub/agent-packs smoke",
    "packs:regression": "corepack pnpm --filter @birthub/agent-packs regression",
    "packs:docs": "corepack pnpm --filter @birthub/agent-packs docs",
    "packs:qa-report": "node --import tsx scripts/pack-qa-report.ts",
    "format": "prettier --write .",
    "lint:workflows": "corepack pnpm --filter @birthub/workflows-core exec eslint . --config eslint.config.mjs --max-warnings=0",
    "db:generate": "corepack pnpm --filter @birthub/database db:generate",
    "db:bootstrap:ci": "corepack pnpm --filter @birthub/database db:bootstrap:ci",
    "db:migrate": "corepack pnpm --filter @birthub/database db:migrate:dev",
    "db:migrate:deploy": "corepack pnpm --filter @birthub/database db:migrate:deploy",
    "db:reset": "corepack pnpm --filter @birthub/database db:reset",
    "db:seed": "corepack pnpm --filter @birthub/database db:seed",
    "billing:sync": "corepack pnpm --filter @birthub/api billing:sync",
    "privacy:verify": "tsx scripts/privacy/verify-anonymization.ts",
    "release:migrate": "tsx scripts/release/final-data-migration.ts",
    "release:preflight:production": "node --import tsx scripts/release/preflight-env.ts --target=production",
    "release:preflight:staging": "node --import tsx scripts/release/preflight-env.ts --target=staging --env-file=ops/release/sealed/.env.staging.sealed",
    "release:smoke": "tsx scripts/release/global-smoke.ts",
    "ops:vps:env": "node scripts/ops/generate-vps-env.mjs",
    "ops:vps:preflight": "node --import tsx scripts/release/preflight-env.ts --target=production --env-file=.env.vps",
    "setup:local": "bash ./scripts/setup/setup-local.sh",
    "reset:local": "bash ./scripts/reset-local.sh",
    "clean": "node scripts/clean.mjs",
    "lockfile:hash:update": "node scripts/ci/write-lockfile-hash.mjs",
    "ci:task": "node scripts/ci/full.mjs task",
    "agent:snapshot": "node scripts/agent/generate-snapshot.mjs",
    "postinstall": "node scripts/postinstall-db-generate.mjs",
    "test:e2e": "playwright test",
    "test:e2e:release": "playwright test tests/e2e/release-master.spec.ts",
    "test:workflows:evidence": "playwright test tests/e2e/workflow-editor-evidence.spec.ts",
    "test:billing:coverage": "node --import tsx scripts/billing/generate-billing-coverage-report.ts",
    "test:python": "pytest apps/webhook-receiver/tests -n auto --dist loadfile",
    "test:load:k6": "k6 run scripts/load-tests/stress.js",
    "test:worker:overload": "tsx scripts/load-tests/worker-overload.ts",
    "test:load": "corepack pnpm --filter @birthub/queue test:load",
    "smoke:satellites": "node scripts/ci/run-satellites.mjs smoke",
    "dev:all-workers": "corepack pnpm -r --parallel --filter \"*-agent-worker\" dev",
    "ci:local": "bash ./scripts/ci/local-ci.sh",
    "workspace:audit": "node scripts/ci/workspace-audit.mjs && node scripts/ci/script-compliance-audit.mjs",
    "monorepo:doctor": "node scripts/ci/monorepo-doctor.mjs",
    "release:scorecard": "node scripts/ci/release-scorecard.mjs",
    "prepare": "husky",
    "test:db:baseline": "node --import tsx scripts/performance/database-baseline.mjs",
    "docs:links": "node scripts/docs/check-doc-links.mjs",
    "docs:dependency-graph": "node scripts/docs/generate-dependency-graph.mjs",
    "docs:health": "node scripts/docs/generate-technical-health-dashboard.mjs",
    "docs:changelog:init": "node scripts/docs/bootstrap-changelogs.mjs",
    "docs:verify": "corepack pnpm docs:links && corepack pnpm docs:dependency-graph && corepack pnpm docs:health",
    "test:python:integration": "pytest apps/webhook-receiver/tests -n auto --dist loadfile",
    "test:python:coverage": "pytest apps/webhook-receiver/tests -n auto --dist loadfile --cov=apps/webhook-receiver --cov-fail-under=80",
    "test:tag:unit": "node scripts/testing/run-tagged-tests.mjs unit",
    "test:tag:integration": "node scripts/testing/run-tagged-tests.mjs integration",
    "test:tag:slow": "node scripts/testing/run-tagged-tests.mjs slow",
    "test:shard": "node scripts/testing/run-shard.mjs",
    "test:traceability": "node scripts/testing/generate-traceability-report.mjs",
    "report:performance": "node scripts/testing/generate-performance-report.mjs",
    "report:regression-zero": "node scripts/testing/generate-regression-zero-report.mjs",
    "db:check:all": "corepack pnpm --filter @birthub/database db:check:all",
    "db:seed:ci": "corepack pnpm --filter @birthub/database db:seed:ci",
    "db:seed:smoke": "corepack pnpm --filter @birthub/database db:seed:smoke",
    "db:seed:staging": "corepack pnpm --filter @birthub/database db:seed:staging",
    "db:validate:pr": "corepack pnpm --filter @birthub/database db:validate:pr",
    "release:rollback:evidence": "node --import tsx scripts/release/verify-rollback-evidence.ts --target=production",
    "release:sbom": "node scripts/release/generate-sbom.mjs",
    "release:materialize": "node --import tsx scripts/release/materialize-release.ts",
    "release:bundle": "corepack pnpm release:sbom && corepack pnpm release:materialize",
    "release:verify:cycle0": "bash ./scripts/release/verify-cycle0-flow.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.7",
      "flatted": ">=3.4.2",
      "next": ">=16.1.7",
      "effect": ">=3.20.0",
      "path-to-regexp": "8.4.0",
      "picomatch": "4.0.4",
      "eslint-import-resolver-typescript>unrs-resolver": "npm:empty-npm-package@1.0.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@types/opossum": "^8.1.9",
    "fast-xml-parser": ">=5.5.8",
    "lru-cache": "^11.2.7",
    "opossum": "^9.0.0",
    "zod": "^4.3.6"
  }
}
