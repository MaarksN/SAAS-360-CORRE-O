# Copy this file to `.env.vps` on the target VPS and keep it out of git.
# This profile assumes:
# 1. web/api/worker run on the VPS via docker compose
# 2. PostgreSQL and Redis are external providers with SSL/TLS enabled
# 3. TLS termination happens in Caddy on the same VPS

# -----------------------------
# Public ingress
# -----------------------------
APP_DOMAIN=app.birthhub360.com
API_DOMAIN=api.birthhub360.com
CADDY_EMAIL=ops@birthhub360.com
NEXT_PUBLIC_APP_URL=https://app.birthhub360.com
NEXT_PUBLIC_API_URL=https://api.birthhub360.com
WEB_BASE_URL=https://app.birthhub360.com
API_CORS_ORIGINS=https://app.birthhub360.com

# -----------------------------
# Runtime
# -----------------------------
LOG_LEVEL=info
QUEUE_NAME=birthub-v1
WORKER_CONCURRENCY=5
API_KEY_PREFIX=bh360_live
AUTH_BCRYPT_SALT_ROUNDS=12
AUTH_MFA_ISSUER=BirthHub360
EMAIL_FROM_ADDRESS=noreply@birthhub360.com
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production
OTEL_SERVICE_NAME=birthub-api
BILLING_EXPORT_STORAGE_MODE=local
BILLING_GRACE_PERIOD_DAYS=3
REQUIRE_SECURE_COOKIES=true
NEXT_PUBLIC_CSP_REPORT_ONLY=false

# -----------------------------
# External data plane
# -----------------------------
# PostgreSQL must satisfy the production validator: include sslmode=require.
DATABASE_URL=postgresql://birthhub:use-a-real-password@postgres-provider.example.com:5432/birthhub?sslmode=require
DIRECT_DATABASE_URL=postgresql://birthhub:use-a-real-password@postgres-provider.example.com:5432/birthhub?sslmode=require

# Redis must satisfy the production validator: use rediss:// or tls=true.
REDIS_URL=rediss://default:use-a-real-password@redis-provider.example.com:6379

# -----------------------------
# Application secrets
# -----------------------------
NEXTAUTH_SECRET=replace-with-64-char-hex
SESSION_SECRET=replace-with-64-char-hex
AUTH_MFA_ENCRYPTION_KEY=replace-with-64-char-hex
JOB_HMAC_GLOBAL_SECRET=replace-with-64-char-hex

# -----------------------------
# Billing / Stripe
# -----------------------------
STRIPE_SECRET_KEY=sk_live_replace_with_real_value
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_value
STRIPE_SUCCESS_URL=https://app.birthhub360.com/billing/success
STRIPE_CANCEL_URL=https://app.birthhub360.com/billing/cancel
STRIPE_PORTAL_RETURN_URL=https://app.birthhub360.com/settings/billing

# -----------------------------
# Observability
# -----------------------------
# The production validator expects Sentry DSNs to be configured.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
EXTERNAL_HEALTHCHECK_URLS=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
